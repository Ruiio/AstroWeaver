# AstroWeaver 环境变量配置模板
# 复制此文件为 .env 并填写实际值
# 注意：不要提交 .env 文件到版本控制

# API 密钥
ASTROWEAVER_ALI_KEY=your_ali_key_here
ASTROWEAVER_ZHIPU_KEY=your_zhipu_key_here
ASTROWEAVER_NVIDIA_KEY=your_nvidia_key_here
ASTROWEAVER_DEEPSEEK_KEY=your_deepseek_key_here
ASTROWEAVER_LLM_KEY=your_default_llm_key_here
ASTROWEAVER_X_API_KEY=your_bocha_key_here
ASTROWEAVER_CLOSEAI_KEY=your_closeai_key_here
ASTROWEAVER_SERPER_KEY=your_serper_key_here

# 数据库密码
ASTROWEAVER_NEO4J_PASSWORD=your_neo4j_password_here

# 可选：代理配置（默认留空）
# HTTP_PROXY=
# HTTPS_PROXY=
